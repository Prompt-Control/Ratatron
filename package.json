{
  "name": "ratatron-livestream",
  "version": "1.0.0",
  "description": "Ratatron - Mobile livestream cooking assistant with direct Google Drive streaming",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "lint": "eslint .",
    "docker:build": "docker build -t ratatron-backend:latest .",
    "docker:run": "docker run -p 3000:3000 --env-file .env ratatron-backend:latest"
  },
  "keywords": ["livestream", "cooking", "ffmpeg", "google-drive", "websocket", "mobile"],
  "author": "Ratatron Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "google-auth-library": "^9.2.0",
    "googleapis": "^118.0.0",
    "multer": "^1.4.5-lts.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "eslint": "^8.51.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1"
  }
}
